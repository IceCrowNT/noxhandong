generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ApartmentType {
  CHUNG_CU
  LIEN_KE
}

enum ApartmentStatus {
  DANG_O
  TRONG
  KHOA
}

enum OccupancyRole {
  CHU_HO
  THUE_CHINH
  THANH_VIEN
}

enum ImportSourceType {
  MANAGEMENT_WORKBOOK
  BANK_STATEMENT
  RECEIPT_IMPORT
}

enum ImportBatchStatus {
  PENDING
  COMPLETED
  FAILED
}

enum RawManagementRowType {
  CUSTOMER
  FEE_HISTORY
  OTHER
}

enum MatchStatus {
  EXACT_MATCH
  NORMALIZED_MATCH
  MULTI_MATCH
  INVALID_CODE
  UNPARSED
  IGNORED_INTERNAL
  NEED_REVIEW
  MANUAL_FIXED
  APPROVED
}

enum ReviewDecisionStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
}

enum AllocationMethod {
  SINGLE
  MULTI_EXACT
  MULTI_PRORATED
  MANUAL
}

enum ExceptionType {
  AN_DIEN
  CK_NHAM
  NOP_HO
  GHI_SAI_MA_CAN
  THIEU_TIEN
  THUA_TIEN
  KHONG_RO_CAN
  NOI_BO
}

enum ExceptionStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum BillingPeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PARTIAL
  PAID
  OVERPAID
  VOID
}

model Apartment {
  id              String                  @id @default(cuid())
  code            String                  @unique
  apartmentType   ApartmentType
  blockCode       String
  roomCode        String
  areaM2          Decimal?                @db.Decimal(10, 2)
  status          ApartmentStatus         @default(DANG_O)
  note            String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  occupancies     Occupancy[]
  invoices        Invoice[]
  allocations     TransactionAllocation[]
  exceptionCases  ExceptionCase[]
  documents       Document[]
}

model Resident {
  id              String       @id @default(cuid())
  fullName        String
  phoneNumber     String?
  zaloLink        String?
  note            String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  occupancies     Occupancy[]
}

model Occupancy {
  id                    String        @id @default(cuid())
  apartmentId           String
  residentId            String
  role                  OccupancyRole
  receiveNotifications  Boolean       @default(true)
  effectiveFrom         DateTime?
  effectiveTo           DateTime?
  isCurrent             Boolean       @default(true)
  note                  String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  apartment             Apartment     @relation(fields: [apartmentId], references: [id], onDelete: Restrict)
  resident              Resident      @relation(fields: [residentId], references: [id], onDelete: Restrict)

  @@index([apartmentId])
  @@index([residentId])
}

model FeeRule {
  id              String          @id @default(cuid())
  apartmentType   ApartmentType
  feeCode         String
  amount          Decimal         @db.Decimal(14, 2)
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  isActive        Boolean         @default(true)
  note            String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  invoiceLines    InvoiceLine[]

  @@index([apartmentType, feeCode, effectiveFrom])
}

model ImportBatch {
  id                  String               @id @default(cuid())
  sourceType          ImportSourceType
  fileName            String
  fileHash            String?
  mimeType            String?
  rowCount            Int?
  status              ImportBatchStatus    @default(PENDING)
  errorSummary        String?
  metadata            Json?
  importedAt          DateTime             @default(now())

  rawManagementRows   RawManagementRow[]
  rawBankRows         RawBankStatementRow[]
  bankTransactions    BankTransaction[]

  @@index([sourceType, importedAt])
}

model RawManagementRow {
  id          String                @id @default(cuid())
  batchId     String
  sheetName   String
  rowIndex    Int
  rowType     RawManagementRowType
  payload     Json
  createdAt   DateTime              @default(now())

  batch       ImportBatch           @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, sheetName, rowIndex])
}

model RawBankStatementRow {
  id          String        @id @default(cuid())
  batchId     String
  rowIndex    Int
  payload     Json
  createdAt   DateTime      @default(now())

  batch       ImportBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, rowIndex])
}

model BankTransaction {
  id                    String                    @id @default(cuid())
  batchId               String
  transactionFingerprint String                   @unique
  bankReference         String?                   @unique
  transactionDate       DateTime?
  amount                Decimal                   @db.Decimal(14, 2)
  descriptionRaw        String
  descriptionNormalized String?
  senderName            String?
  senderAccount         String?
  transactionIdText     String?
  rawPayload            Json?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  batch                 ImportBatch               @relation(fields: [batchId], references: [id], onDelete: Restrict)
  parseResult           TransactionParseResult?
  reviews               TransactionReview[]
  allocations           TransactionAllocation[]
  exceptionCases        ExceptionCase[]
  documents             Document[]

  @@index([batchId])
  @@index([transactionDate])
}

model TransactionParseResult {
  id                    String             @id @default(cuid())
  transactionId         String             @unique
  parserVersion         String?
  parsedApartmentCode   String?
  matchStatus           MatchStatus
  matchReason           String
  matchConfidence       Decimal?           @db.Decimal(5, 2)
  isInternalTransaction Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  transaction           BankTransaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  candidates            TransactionCandidate[]
}

model TransactionCandidate {
  id              String                  @id @default(cuid())
  parseResultId   String
  apartmentCode   String
  score           Decimal                 @db.Decimal(5, 2)
  reason          String
  rankOrder       Int
  createdAt       DateTime                @default(now())

  parseResult     TransactionParseResult  @relation(fields: [parseResultId], references: [id], onDelete: Cascade)

  @@index([parseResultId, rankOrder])
}

model TransactionReview {
  id                    String                @id @default(cuid())
  transactionId         String
  decisionStatus        ReviewDecisionStatus  @default(PENDING)
  selectedApartmentCode String?
  reviewNote            String?
  reviewedBy            String?
  reviewedAt            DateTime?
  payload               Json?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  transaction           BankTransaction       @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId, createdAt])
}

model TransactionAllocation {
  id                String             @id @default(cuid())
  transactionId     String
  apartmentId       String?
  allocatedAmount   Decimal            @db.Decimal(14, 2)
  allocationMethod  AllocationMethod
  allocationNote    String?
  sequenceNo        Int                @default(1)
  isConfirmed       Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  transaction       BankTransaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  apartment         Apartment?         @relation(fields: [apartmentId], references: [id], onDelete: Restrict)
  paymentApplications PaymentApplication[]

  @@index([transactionId, sequenceNo])
  @@index([apartmentId])
}

model ExceptionCase {
  id                String            @id @default(cuid())
  transactionId     String
  apartmentId       String?
  exceptionType     ExceptionType
  amount            Decimal           @db.Decimal(14, 2)
  status            ExceptionStatus   @default(OPEN)
  resolutionNote    String?
  resolvedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  transaction       BankTransaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  apartment         Apartment?        @relation(fields: [apartmentId], references: [id], onDelete: Restrict)

  @@index([transactionId])
  @@index([apartmentId])
}

model BillingPeriod {
  id              String               @id @default(cuid())
  periodKey       String               @unique
  month           Int
  year            Int
  startDate       DateTime?
  endDate         DateTime?
  status          BillingPeriodStatus  @default(OPEN)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  invoices        Invoice[]

  @@index([year, month])
}

model Invoice {
  id                String                 @id @default(cuid())
  apartmentId       String
  billingPeriodId   String
  carryOverAmount   Decimal                @default(0) @db.Decimal(14, 2)
  totalCharge       Decimal                @default(0) @db.Decimal(14, 2)
  totalPaid         Decimal                @default(0) @db.Decimal(14, 2)
  balanceAmount     Decimal                @default(0) @db.Decimal(14, 2)
  status            InvoiceStatus          @default(DRAFT)
  note              String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  apartment         Apartment              @relation(fields: [apartmentId], references: [id], onDelete: Restrict)
  billingPeriod     BillingPeriod          @relation(fields: [billingPeriodId], references: [id], onDelete: Restrict)
  lines             InvoiceLine[]
  paymentApplications PaymentApplication[]

  @@unique([apartmentId, billingPeriodId])
  @@index([billingPeriodId])
}

model InvoiceLine {
  id              String        @id @default(cuid())
  invoiceId       String
  feeCode         String
  description     String?
  quantity        Decimal       @default(1) @db.Decimal(10, 2)
  unitPrice       Decimal       @default(0) @db.Decimal(14, 2)
  amount          Decimal       @default(0) @db.Decimal(14, 2)
  sourceRuleId    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sourceRule      FeeRule?      @relation(fields: [sourceRuleId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
}

model PaymentApplication {
  id              String                @id @default(cuid())
  allocationId    String
  invoiceId       String
  appliedAmount   Decimal               @db.Decimal(14, 2)
  appliedAt       DateTime              @default(now())
  note            String?

  allocation      TransactionAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  invoice         Invoice               @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([allocationId])
  @@index([invoiceId])
}

model Document {
  id                String            @id @default(cuid())
  apartmentId       String?
  transactionId     String?
  documentType      String
  storagePath       String
  originalFileName  String?
  documentDate      DateTime?
  note              String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  apartment         Apartment?        @relation(fields: [apartmentId], references: [id], onDelete: Restrict)
  transaction       BankTransaction?  @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  @@index([apartmentId])
  @@index([transactionId])
}
