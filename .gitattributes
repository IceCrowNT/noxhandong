* text=auto

# Keep source and documentation stable across Windows/VPS/Linux.
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.prisma text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows scripts should keep Windows line endings.
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary uploads/assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.xlsx binary
*.xls binary
*.dump binary
