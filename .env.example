DATABASE_URL="postgresql://postgres:postgres@localhost:5432/apartment_fee_reviewer?schema=public"

# Required in production. Use a long random value.
ADMIN_SESSION_SECRET="change-me-with-a-long-random-production-secret"

# Used by npm run seed:v2.
ADMIN_INITIAL_PASSWORD="change-me"
ADMIN_INITIAL_PHONE=""

# Optional operational export directory.
EXPORT_DIR=".local/exports"
